APP_NAME="Control S Fiscal Hub"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8088

DB_DSN=pgsql:host=127.0.0.1;port=5432;dbname=control_s_fiscal_hub
DB_USER=controls
DB_PASS=controls123

AUTH_ENABLED=true
AUTH_USER=admin
AUTH_PASS=admin
AUTH_DEFAULT_EMAIL=admin@controls.local

APP_KEY=troque-esta-chave-por-uma-chave-grande-e-unica
DEFAULT_DOWNLOAD_DIR=C:\Control S Fiscal Hub\app\storage\xmls
AUTO_MIGRATE=true
TIMEZONE=America/Sao_Paulo

SEFAZ_ENVIRONMENT=1
SEFAZ_UF_AUTHOR=41
SEFAZ_MAX_LOOPS=8
SEFAZ_TIMEOUT=60
SEFAZ_USER_AGENT="ControlSPortalFiscal/3.0"

NFE_DISTRIBUTION_URL="https://www1.nfe.fazenda.gov.br/NFeDistribuicaoDFe/NFeDistribuicaoDFe.asmx"
NFE_DISTRIBUTION_ACTION="http://www.portalfiscal.inf.br/nfe/wsdl/NFeDistribuicaoDFe/nfeDistDFeInteresse"
NFE_RECEPCAOEVENTO_URL="https://www1.nfe.fazenda.gov.br/NFeRecepcaoEvento4/NFeRecepcaoEvento4.asmx"
NFE_RECEPCAOEVENTO_ACTION="http://www.portalfiscal.inf.br/nfe/wsdl/NFeRecepcaoEvento4/nfeRecepcaoEventoNF"

CTE_DISTRIBUTION_URL="https://www1.cte.fazenda.gov.br/CTeDistribuicaoDFe/CTeDistribuicaoDFe.asmx"
CTE_DISTRIBUTION_ACTION="http://www.portalfiscal.inf.br/cte/wsdl/CTeDistribuicaoDFe/cteDistDFeInteresse"

NFSE_ENVIRONMENT=production
NFSE_BASE_URL="https://adn.nfse.gov.br"
NFSE_DISTRIBUTION_PATH="/contribuintes/DFe/{nsu}"
NFSE_AUTH_TYPE=certificate
NFSE_TOKEN=
NFSE_PAGE_SIZE=10

AUTO_CTE_ENABLED=0
AUTO_CTE_COMPANY_ID=0
AUTO_CTE_INTERVAL_MINUTES=30
CTE_ROBOT_MAX_CYCLES=10
CTE_ROBOT_TIME_LIMIT_SECONDS=240

AUTO_NFE_ENABLED=0
AUTO_NFE_COMPANY_ID=0
AUTO_NFE_INTERVAL_MINUTES=60
AUTO_NFE_MANIFEST_SCIENCE=0
NFE_ROBOT_MAX_CYCLES=4
NFE_ROBOT_TIME_LIMIT_SECONDS=180
NFE_SCIENCE_LIMIT_PER_RUN=30

AUTO_NFSE_ENABLED=0
AUTO_NFSE_COMPANY_ID=0
AUTO_NFSE_INTERVAL_MINUTES=60
AUTO_NFSE_NSU_LIMIT=10
