APP_NAME="Control S - Portal Fiscal (XML)"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8088

DB_DSN=pgsql:host=db;port=5432;dbname=controls_portal
DB_USER=controls
DB_PASS=controls123

AUTH_ENABLED=false
AUTH_USER=admin
AUTH_PASS=admin

APP_KEY=change-this-32-char-key
DEFAULT_DOWNLOAD_DIR=/var/www/html/storage/xmls
AUTO_MIGRATE=true
TIMEZONE=America/Sao_Paulo

SEFAZ_ENVIRONMENT=1
SEFAZ_UF_AUTHOR=41
SEFAZ_MAX_LOOPS=8
SEFAZ_TIMEOUT=60
SEFAZ_USER_AGENT="ControlSPortalFiscal/3.0"

NFE_DISTRIBUTION_URL="https://www1.nfe.fazenda.gov.br/NFeDistribuicaoDFe/NFeDistribuicaoDFe.asmx"
NFE_DISTRIBUTION_ACTION="http://www.portalfiscal.inf.br/nfe/wsdl/NFeDistribuicaoDFe/nfeDistDFeInteresse"
NFE_RECEPCAOEVENTO_URL="https://www.nfe.fazenda.gov.br/RecepcaoEvento4/RecepcaoEvento4.asmx"
NFE_RECEPCAOEVENTO_ACTION="http://www.portalfiscal.inf.br/nfe/wsdl/RecepcaoEvento4/nfeRecepcaoEvento"

CTE_DISTRIBUTION_URL="https://www1.cte.fazenda.gov.br/CTeDistribuicaoDFe/CTeDistribuicaoDFe.asmx"
CTE_DISTRIBUTION_ACTION="http://www.portalfiscal.inf.br/cte/wsdl/CTeDistribuicaoDFe/cteDistDFeInteresse"

NFSE_ENVIRONMENT=production
NFSE_BASE_URL="https://adn.nfse.gov.br"
NFSE_DISTRIBUTION_PATH="/contribuintes/api/v1/distribuicao"
NFSE_AUTH_TYPE=certificate
